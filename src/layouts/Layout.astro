---
import '../globals.css';
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
        <title>{title || 'Portfolio'}</title>
    </head>
    <body class="bg-black text-white antialiased">
        <slot />
    </body>
</html>
